# Palqueate — configuración de entorno (frontend / Vite)
# Copiá este archivo a `.env` (o `.env.local`) y ajustá los valores.
# Solo las variables con prefijo VITE_ se exponen al cliente.

# Origen de datos:
#   memory → adaptadores in-memory (demo, sin backend) — valor por defecto
#   http   → consume la API real vía los adaptadores HTTP
VITE_DATA_SOURCE=memory

# Base URL de la API cuando VITE_DATA_SOURCE=http.
# Mismo origen detrás de un proxy: /api  ·  Origen distinto: https://api.palqueate.uy/v1
VITE_API_BASE_URL=/api

# Timeout de cada request HTTP, en milisegundos (opcional).
VITE_API_TIMEOUT_MS=15000
